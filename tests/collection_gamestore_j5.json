    {
      "name": "05 — Featured (NGS-108)",
      "item": [
        {
          "name": "Featured — réponse de base",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// TODO 1 — Status 200",
                  "pm.test(\"Status 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    });",
                  "// TODO 2 — Réponse contient 'count' et 'featured'",
                  "pm.test(\"Réponse contient 'count' et 'featured'\", function () {",
                  "    pm.expect(pm.response.json()).to.have.property('count');",
                  "    pm.expect(pm.response.json()).to.have.property('featured');",
                  "    });",
                  "",
                  "// TODO 3 — 'featured' est un tableau de max 5 éléments",
                  "pm.test(\"Le tableau 'featured' contient au maximum 5 éléments\", function () {",
                  "    pm.expect(pm.response.json().featured).to.have.lengthOf.at.most(5);",
                  "    });",
                  "",
                  "// TODO 4 — Les jeux sont triés par rating décroissant",
                  "// Si ce test échoue alors que votre assertion est correcte,",
                  "// notez ce que vous observez — c'est important.",
                  "pm.test(\"Les jeux sont triés par rating décroissant\", function () {",
                  "    const featured = pm.response.json().featured;",
                  "    for (let i = 0; i < featured.length - 1; i++) {",
                  "        pm.expect(featured[i].rating).to.be.at.least(featured[i + 1].rating);",
                  "        }",
                  "        });"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
